{
  "name": "tijian-report",
  "region": "us",
  "plan": "free",
  "services": [
    {
      "name": "web",
      "type": "web",
      "runtime": "python",
      "build": {
        "command": "pip install -r requirements.txt"
      },
      "run": "streamlit run app.py --server.port $PORT",
      "port": 8501,
      "env": {
        "STREAMLIT_SERVER_PORT": {
          "value": "8501"
        }
      }
    }
  ]
}
